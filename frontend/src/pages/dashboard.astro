---
import Layout from '../layouts/Layout.astro';
import Map from '../components/Map.astro';
import { getAccidentPoints } from '../services/api';

const mockData = await getAccidentPoints();

const totalIncidents = mockData.reduce((acc, curr) => acc + curr.incidents, 0);
const criticalPoints = mockData.filter(p => p.riskLevel === 'Crítico' || p.riskLevel === 'Alto').length;

// Ordenamos de mayor a menor para la lista
const sortedData = [...mockData].sort((a, b) => b.incidents - a.incidents);
---

<Layout title="Dashboard Autoridades">
    <div class="h-screen w-full flex bg-gray-100 overflow-hidden">
        
        <!-- Sidebar Izquierdo: Menú y Métricas -->
        <aside class="w-96 bg-white shadow-xl z-20 flex flex-col h-full border-r border-gray-200">
            <!-- Logo y Cabecera -->
            <div class="p-6 border-b border-gray-100 flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-blue-900 flex items-center justify-center text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                </div>
                <div>
                    <h1 class="font-bold text-xl text-gray-900 leading-tight">VíaAlerta</h1>
                    <p class="text-xs text-gray-500 font-medium tracking-wide uppercase">Centro de Control</p>
                </div>
            </div>

            <!-- Contenido del Sidebar scrollable -->
            <div class="flex-grow overflow-y-auto p-6">
                
                <!-- KPIs -->
                <div class="grid grid-cols-2 gap-4 mb-8">
                    <div class="bg-blue-50 rounded-xl p-4 border border-blue-100">
                        <p class="text-sm text-blue-600 font-semibold mb-1">Total Accidentes</p>
                        <p class="text-3xl font-bold text-blue-900">{totalIncidents}</p>
                    </div>
                    <div class="bg-red-50 rounded-xl p-4 border border-red-100">
                        <p class="text-sm text-red-600 font-semibold mb-1">Puntos Críticos</p>
                        <p class="text-3xl font-bold text-red-900">{criticalPoints}</p>
                    </div>
                </div>

                <!-- Lista de Cruces Peligrosos -->
                <div>
                    <div class="flex justify-between items-end mb-4">
                        <h2 class="font-bold text-gray-900 text-lg">Top Zonas de Riesgo</h2>
                        <button class="text-sm text-blue-600 font-medium hover:underline">Ver reporte</button>
                    </div>
                    
                    <div class="flex flex-col gap-3">
                        {sortedData.map((punto, index) => (
                            <div class="bg-white border border-gray-200 rounded-xl p-4 hover:shadow-md transition cursor-pointer flex gap-4 items-center">
                                <div class={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm text-white ${punto.riskLevel === 'Crítico' ? 'bg-red-800' : punto.riskLevel === 'Alto' ? 'bg-red-500' : 'bg-orange-500'}`}>
                                    {index + 1}
                                </div>
                                <div class="flex-grow">
                                    <h3 class="text-sm font-bold text-gray-900 leading-tight mb-1">{punto.intersection}</h3>
                                    <p class="text-xs text-gray-500">{punto.district}</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-lg font-bold text-gray-900">{punto.incidents}</p>
                                    <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider">Casos</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>

            </div>

            <!-- Footer Sidebar -->
            <div class="p-4 border-t border-gray-100 bg-gray-50 text-center">
                <p class="text-xs text-gray-500 font-medium">Última actualización: Hoy, 14:00 hrs</p>
            </div>
        </aside>

        <!-- Área Principal: Mapa Completo -->
        <main class="flex-grow relative z-0">
            <!-- Search bar overlay -->
            <div class="absolute top-6 left-6 z-20 w-96">
                <div class="bg-white rounded-xl shadow-lg flex items-center px-4 py-3 border border-gray-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text" placeholder="Buscar distrito o cruce..." class="w-full outline-none text-gray-700 bg-transparent placeholder-gray-400">
                </div>
            </div>

            <!-- Map Component -->
            <!-- Lima center and zoomed out -->
            <Map points={mockData} centerLat={-12.06} centerLng={-77.03} zoom={12} />
        </main>
    </div>
</Layout>
