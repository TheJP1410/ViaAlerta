---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ViaAlerta</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <main class="mx-auto flex min-h-screen w-full max-w-4xl flex-col gap-6 px-4 py-10 sm:px-8">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">ViaAlerta</h1>
      <p class="max-w-2xl text-base text-slate-700 sm:text-lg">
        Plataforma web para visualizar zonas con mayor riesgo de accidentes de tránsito.
      </p>
      <section class="grid gap-4 sm:grid-cols-2">
        <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
          <h2 class="text-lg font-semibold">Mapa interactivo</h2>
          <p class="mt-2 text-sm text-slate-600">Diseñado para peatones y ciclistas con alertas en cruces peligrosos.</p>
        </article>
        <article class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
          <h2 class="text-lg font-semibold">Panel predictivo</h2>
          <p class="mt-2 text-sm text-slate-600">Soporta decisiones municipales con datos abiertos de seguridad vial.</p>
        </article>
      </section>
    </main>
  </body>
</html>
