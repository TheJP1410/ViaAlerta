---
import Layout from '../layouts/Layout.astro';
import CitizenView from '../components/CitizenView.vue';
import { getAccidentPoints } from '../services/api';

const points = await getAccidentPoints();
---

<Layout title="Ciudadano">
    <CitizenView client:only="vue" points={points} />
</Layout>

<style>
    :global(.leaflet-control-attribution) {
        display: none;
    }
</style>
