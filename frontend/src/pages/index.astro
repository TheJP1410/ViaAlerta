---
import Layout from '../layouts/Layout.astro';
import Map from '../components/Map.astro';
import { getAccidentPoints } from '../services/api';

const mockData = await getAccidentPoints();

// Simulated nearest point for the user
const nearestDanger = mockData[0]; // "Av. Javier Prado con Av. Aviación"
---

<Layout title="Ciudadano">
    <main class="relative h-screen w-full flex flex-col bg-gray-50 overflow-hidden">
        
        <!-- Header -->
        <header class="bg-white px-5 py-4 shadow-sm z-10 flex justify-between items-center relative">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-red-500 flex items-center justify-center text-white font-bold text-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-1.998A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd" />
                    </svg>
                </div>
                <h1 class="font-bold text-xl tracking-tight text-gray-900">VíaAlerta</h1>
            </div>
            <button class="p-2 bg-gray-100 rounded-full text-gray-600 hover:bg-gray-200 transition">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
        </header>

        <!-- Predictive Alert Banner -->
        <div class="absolute top-20 left-0 w-full px-4 z-20 pointer-events-none transition-transform transform translate-y-0" id="alert-banner">
            <div class="bg-red-500 text-white p-4 rounded-2xl shadow-xl flex items-start gap-4 pointer-events-auto border-2 border-red-400">
                <div class="mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <div>
                    <p class="font-bold text-lg leading-tight mb-1">¡Cuidado! Zona Crítica a 200m</p>
                    <p class="text-red-100 text-sm leading-snug">{nearestDanger.intersection}</p>
                    <p class="text-red-100 text-sm leading-snug font-medium mt-1">Causa común: {nearestDanger.commonCause}</p>
                </div>
            </div>
        </div>

        <!-- Map Area -->
        <div class="flex-grow relative z-0">
            <!-- Overlay gradient for soft blend with header/footer -->
            <div class="absolute top-0 w-full h-8 bg-gradient-to-b from-black/5 to-transparent z-10 pointer-events-none"></div>
            
            <Map points={mockData} centerLat={nearestDanger.lat} centerLng={nearestDanger.lng} zoom={15} />
            
            <!-- Locate Me FAB -->
            <button class="absolute bottom-32 right-4 bg-white p-3 rounded-full shadow-lg z-20 border border-gray-100 text-blue-600 hover:bg-gray-50">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
            </button>
        </div>

        <!-- Bottom Sheet (Ruta Actual) -->
        <div class="bg-white rounded-t-3xl shadow-[0_-10px_40px_rgba(0,0,0,0.08)] z-20 absolute bottom-0 w-full transition-transform duration-300">
            <div class="w-12 h-1.5 bg-gray-200 rounded-full mx-auto mt-3 mb-4"></div>
            <div class="px-6 pb-8">
                <h2 class="text-gray-900 font-bold text-lg mb-4">Tu ruta actual</h2>
                
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                          <path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-medium">Destino</p>
                        <p class="text-gray-900 font-semibold">San Isidro, Centro Financiero</p>
                    </div>
                </div>

                <div class="bg-orange-50 rounded-xl p-4 border border-orange-100 flex gap-3 items-center">
                    <div class="text-orange-500">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <p class="text-sm text-orange-800 font-medium leading-tight">
                        La ruta sugerida incluye <strong class="font-bold">2 puntos críticos</strong> para ciclistas.
                    </p>
                </div>
            </div>
        </div>

    </main>
</Layout>

<style>
    /* Ocultar el map-credits en movil para mas limpieza visual */
    :global(.leaflet-control-attribution) {
        display: none;
    }
</style>
